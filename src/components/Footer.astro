---
// Footer.astro - Komponen footer lengkap dengan script
import { SITE_CONFIG, SERVICES, MATERIALS } from '../utils/constants.js';
---

<footer class="bg-charcoal text-silver-light">
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <div class="flex items-center space-x-3 mb-6">
          <img
            src="/public/images/logo.webp"
            alt="Tepat Laser Logo"
            class="h-10 w-auto"
            width="120"
            height="40"
            onerror="this.src='/public/images/Logo.webp'"
          />
          <div>
            <h3 class="text-xl font-bold">Tepat Laser</h3>
            <p class="text-sm text-graphite">Laser Cutting Terpercaya</p>
          </div>
        </div>
        <p class="text-graphite mb-6">Solusi laser cutting profesional dengan teknologi terdepan. 10+ tahun pengalaman melayani berbagai industri di Jabodetabek.</p>
        <div class="flex space-x-4">
          <a href={SITE_CONFIG.socialMedia.facebook} class="w-10 h-10 bg-silver-mid hover:bg-laser-green rounded-lg flex items-center justify-center transition">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073..."/></svg>
          </a>
          <a href={SITE_CONFIG.socialMedia.instagram} class="w-10 h-10 bg-silver-mid hover:bg-pink-600 rounded-lg flex items-center justify-center transition">
            <svg class="w-5 h-5 text-white"><path d="M12.017..."/></svg>
          </a>
          <a href={SITE_CONFIG.socialMedia.youtube} class="w-10 h-10 bg-silver-mid hover:bg-red-600 rounded-lg flex items-center justify-center transition">
            <svg class="w-5 h-5 text-white"><path d="M23.498..."/></svg>
          </a>
          <a href={SITE_CONFIG.socialMedia.linkedin} class="w-10 h-10 bg-silver-mid hover:bg-blue-700 rounded-lg flex items-center justify-center transition">
            <svg class="w-5 h-5 text-white"><path d="M20.447..."/></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-6">Layanan Kami</h4>
        <ul class="space-y-3 text-graphite">
          {SERVICES.map(s => (
            <li>
              <a href={`/jasalasercutting/${s.slug}`} class="flex items-center hover:text-silver-light transition">
                <svg class="w-4 h-4 mr-2 text-laser-green"><path d="M9 5l7 7-7 7"/></svg>
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-6">Material</h4>
        <ul class="space-y-3 text-graphite">
          {MATERIALS.map(m => (
            <li>
              <a href={`/jasalasercutting/${m.slug}`} class="flex items-center hover:text-silver-light transition">
                <svg class="w-4 h-4 mr-2 text-laser-green"><path d="M9 5l7 7-7 7"/></svg>
                {m.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-6">Kontak Kami</h4>
        <div class="space-y-4 text-graphite">
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-laser-green mt-1"><path d="M17.657..."/></svg>
            <p>{SITE_CONFIG.address}</p>
          </div>
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-laser-green"><path d="M3 5a2..."/></svg>
            <a href={`tel:${SITE_CONFIG.phone}`} class="hover:text-silver-light">{SITE_CONFIG.phone}</a>
          </div>
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-laser-green"><path d="M3 8l7..."/></svg>
            <a href={`mailto:${SITE_CONFIG.email}`} class="hover:text-silver-light">{SITE_CONFIG.email}</a>
          </div>
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-laser-green mt-1"><path d="M12 8v4l3 3..."/></svg>
            <p>{SITE_CONFIG.businessHours}</p>
          </div>
          <a href={`https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}`} class="inline-flex items-center space-x-2 bg-laser-green hover:bg-laser-green/90 text-white px-4 py-2 rounded-lg">
            <svg class="w-4 h-4"><path d="M17.472..."/></svg>
            <span>Chat WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-silver-mid">
    <div class="container-custom py-6 flex flex-col md:flex-row justify-between text-graphite text-sm">
      <p>© 2024 Tepat Laser. All rights reserved. | <a href="/privacy-policy" class="hover:text-silver-light">Privacy Policy</a> | <a href="/terms-of-service" class="hover:text-silver-light">Terms of Service</a></p>
      <p class="mt-4 md:mt-0">Melayani: Bandung, Bekasi, Bogor, Depok, Cimahi, Sukabumi & Sekitarnya</p>
    </div>
  </div>

  <button id="back-to-top" class="fixed bottom-6 left-6 w-12 h-12 bg-laser-green hover:bg-laser-green/90 text-white rounded-full shadow-lg transition transform translate-y-16 opacity-0 z-40">
    <svg class="w-6 h-6"><path d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
  </button>

  <script>
    const backToTopButton = document.getElementById('back-to-top');
    if (backToTopButton) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          backToTopButton.classList.remove('translate-y-16', 'opacity-0');
          backToTopButton.classList.add('translate-y-0', 'opacity-100');
        } else {
          backToTopButton.classList.remove('translate-y-0', 'opacity-100');
          backToTopButton.classList.add('translate-y-16', 'opacity-0');
        }
      });
      backToTopButton.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    document.addEventListener('DOMContentLoaded', () => {
      const logoImg = document.querySelector('footer img[alt="Tepat Laser Logo"]');
      const fallback = document.querySelector('.fallback-logo');
      if (logoImg) {
        logoImg.addEventListener('error', () => {
          logoImg.style.display = 'none';
          if (fallback) fallback.style.display = 'flex';
        });
        logoImg.addEventListener('load', () => {
          if (fallback) fallback.style.display = 'none';
        });
      }
    });
  </script>
</footer>
