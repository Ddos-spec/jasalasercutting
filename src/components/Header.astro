---
import { NAVIGATION, SITE_CONFIG } from '../utils/constants.js';

interface NavigationItem {
  name: string;
  href: string;
  submenu?: Array<{ name: string; href: string }>;
  active?: boolean;
}

function createUrl(path: string | null | undefined): string {
  if (!path) return SITE_CONFIG.url || '/';
  const clean = path.startsWith('/') ? path.slice(1) : path;
  if (clean === '' || clean === '/') return SITE_CONFIG.url || '/';
  return clean.startsWith('#')
    ? `${SITE_CONFIG.url}${clean}`
    : `${SITE_CONFIG.url}${clean}`;
}

const processedNavigation: NavigationItem[] = (NAVIGATION ?? [])
  .filter(item => item.name !== 'Kontak')
  .map(item => ({
    ...item,
    href: createUrl(item.href),
    submenu: item.submenu?.map(s => ({
      ...s,
      href: createUrl(s.href)
    })),
    active: false
  }));
---

<header id="main-header" class="fixed top-0 inset-x-0 z-50 bg-white/95 backdrop-blur-md border-b border-silver-mid shadow-lg transition-all duration-300">
  <div class="container-custom">
    <div class="flex items-center justify-between h-20">
      <!-- Logo Section -->
      <a href={SITE_CONFIG.url} class="flex items-center space-x-4 group">
        <div class="relative">
          <img
            src="/jasalasercutting/images/logo.webp"
            alt="Jasa Laser Cutting Logo"
            class="h-12 w-auto transition-transform duration-300 group-hover:scale-105"
            width="120"
            height="48"
            onerror="this.src='/jasalasercutting/images/Logo.webp'"
          />
          <div class="absolute -inset-2 bg-laser-green/10 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>
        <div class="hidden md:block">
          <h1 class="text-2xl font-bold text-charcoal group-hover:text-laser-green transition-colors duration-300">Jasa Laser Cutting</h1>
          <p class="text-sm text-graphite font-medium">Laser Cutting Terpercaya</p>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav aria-label="Main navigation" class="hidden lg:flex items-center space-x-1">
        {processedNavigation.map((item, i) => (
          <div class="relative group">
            {item.submenu ? (
              <>
                <button
                  class="desktop-dropdown-btn flex items-center space-x-2 text-charcoal hover:text-laser-green font-semibold px-4 py-3 rounded-lg hover:bg-silver-light transition-all duration-300 group"
                  data-dropdown-index={i}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  <span>{item.name}</span>
                  <svg class="w-4 h-4 dropdown-arrow transition-transform duration-300 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                  </svg>
                </button>
                <div
                  data-dropdown-menu={i}
                  class="dropdown-menu hidden absolute top-full left-0 mt-2 w-64 bg-white rounded-xl shadow-xl border border-silver-mid py-3 z-50 transform opacity-0 scale-95 transition-all duration-300"
                >
                  {item.submenu.map(s => (
                    <a
                      href={s.href}
                      class="flex items-center px-4 py-3 text-graphite hover:text-laser-green hover:bg-silver-light text-sm font-medium transition-all duration-300 group"
                    >
                      <div class="w-2 h-2 bg-laser-green rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                      {s.name}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class="relative text-charcoal hover:text-laser-green font-semibold px-4 py-3 rounded-lg hover:bg-silver-light transition-all duration-300 group"
                class:list={{ 'text-laser-green bg-silver-light': item.active }}
              >
                {item.name}
                <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-0 h-0.5 bg-laser-green group-hover:w-8 transition-all duration-300"></div>
              </a>
            )}
          </div>
        ))}
      </nav>

      <!-- CTA Button & Mobile Menu -->
      <div class="flex items-center space-x-4">
        <a href={createUrl('contact')} class="hidden lg:flex btn-primary text-sm shadow-lg hover:shadow-xl">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Kontak Kami
        </a>
        
        <button
          id="mobile-menu-button"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          class="lg:hidden flex items-center justify-center w-12 h-12 rounded-xl hover:bg-silver-light transition-all duration-300 group"
        >
          <div class="relative w-6 h-6">
            <span id="menu-line-1" class="absolute top-1 left-0 w-6 h-0.5 bg-charcoal group-hover:bg-laser-green transition-all duration-300 transform origin-center"></span>
            <span id="menu-line-2" class="absolute top-3 left-0 w-6 h-0.5 bg-charcoal group-hover:bg-laser-green transition-all duration-300"></span>
            <span id="menu-line-3" class="absolute top-5 left-0 w-6 h-0.5 bg-charcoal group-hover:bg-laser-green transition-all duration-300 transform origin-center"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 top-0 bg-white z-50 hidden overflow-y-auto lg:hidden transform translate-x-full transition-transform duration-300">
    <!-- Mobile Header -->
    <div class="flex items-center justify-between h-20 px-6 border-b border-silver-mid bg-white sticky top-0 z-10">
      <a href={SITE_CONFIG.url} class="flex items-center space-x-3">
        <img
          src="/jasalasercutting/images/logo.webp"
          alt="Jasa Laser Cutting Logo"
          class="h-10 w-auto"
          width="120"
          height="40"
          onerror="this.src='/jasalasercutting/images/Logo.webp'"
        />
        <div>
          <h1 class="text-xl font-bold text-charcoal">Jasa Laser Cutting</h1>
          <p class="text-xs text-graphite">Laser Cutting Terpercaya</p>
        </div>
      </a>
      <button 
        id="mobile-menu-close-button" 
        aria-label="Close mobile menu" 
        class="w-12 h-12 flex items-center justify-center rounded-xl hover:bg-silver-light transition-all duration-300 group"
      >
        <svg class="w-6 h-6 text-charcoal group-hover:text-laser-green transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
    </div>
    
    <!-- Mobile Navigation -->
    <nav class="flex flex-col px-6 py-6 space-y-2" role="navigation" aria-label="Mobile navigation">
      {processedNavigation.map((item, i) => (
        <div class="border-b border-silver-mid/30 pb-4 mb-4 last:border-b-0 last:pb-0 last:mb-0">
          {item.submenu ? (
            <div class="mobile-nav-item">
              <button
                data-mobile-submenu-index={i}
                aria-expanded="false"
                aria-controls={`mobile-submenu-${i}`}
                class="mobile-dropdown-btn flex justify-between items-center w-full text-left text-charcoal font-semibold py-4 px-4 rounded-xl hover:bg-silver-light/50 active:bg-silver-light transition-all duration-300 group focus:outline-none focus:ring-2 focus:ring-laser-green/30"
              >
                <span class="group-hover:text-laser-green transition-colors duration-300">{item.name}</span>
                <svg 
                  class="w-5 h-5 text-graphite mobile-dropdown-arrow transition-all duration-300 group-hover:text-laser-green transform" 
                  viewBox="0 0 24 24" 
                  fill="none" 
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                </svg>
              </button>
              <div 
                id={`mobile-submenu-${i}`}
                data-mobile-submenu={i} 
                class="mobile-submenu hidden pl-4 space-y-1 mt-2 transform transition-all duration-300 opacity-0 max-h-0 overflow-hidden"
                role="menu"
                aria-label={`${item.name} submenu`}
              >
                {item.submenu.map((s, subIndex) => (
                  <a 
                    href={s.href} 
                    class="flex items-center text-graphite py-3 px-4 rounded-xl hover:bg-silver-light/50 hover:text-laser-green active:bg-silver-light transition-all duration-300 group focus:outline-none focus:ring-2 focus:ring-laser-green/30"
                    role="menuitem"
                    tabindex="-1"
                  >
                    <div class="w-2 h-2 bg-laser-green rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    <span class="font-medium">{s.name}</span>
                    <svg class="w-4 h-4 ml-auto opacity-0 group-hover:opacity-100 transition-all duration-300 text-laser-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a 
              href={item.href} 
              class="mobile-nav-item flex items-center justify-between text-charcoal font-semibold py-4 px-4 rounded-xl hover:bg-silver-light/50 hover:text-laser-green active:bg-silver-light transition-all duration-300 group focus:outline-none focus:ring-2 focus:ring-laser-green/30"
              class:list={{ 'text-laser-green bg-silver-light/50': item.active }}
            >
              <div class="flex items-center">
                <div class="w-2 h-2 bg-laser-green rounded-full mr-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <span>{item.name}</span>
              </div>
              <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-all duration-300 text-laser-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          )}
        </div>
      ))}
      
      <!-- Mobile CTA Section -->
      <div class="pt-6 mt-6 border-t border-silver-mid/30">
        <a 
          href={createUrl('contact')} 
          class="btn-primary w-full text-center py-4 text-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-laser-green/30"
        >
          <svg class="w-5 h-5 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          Kontak Kami
        </a>
        
        <!-- Additional Mobile Actions -->
        <div class="mt-4 flex flex-col space-y-2">
          <button 
            id="mobile-search-btn"
            class="flex items-center justify-center w-full py-3 px-4 text-graphite hover:text-laser-green hover:bg-silver-light/50 rounded-xl transition-all duration-300 group focus:outline-none focus:ring-2 focus:ring-laser-green/30"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span class="font-medium">Cari Layanan</span>
          </button>
        </div>
      </div>
    </nav>
  </div>
  
  <!-- Mobile Menu Overlay -->
  <div 
    id="mobile-menu-overlay" 
    class="fixed inset-0 bg-charcoal/50 z-40 hidden lg:hidden opacity-0 transition-opacity duration-300 backdrop-blur-sm"
    aria-hidden="true"
  ></div>

  <script type="module">
    document.addEventListener('DOMContentLoaded', () => {
      // Elements
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenuCloseButton = document.getElementById('mobile-menu-close-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
      const menuLine1 = document.getElementById('menu-line-1');
      const menuLine2 = document.getElementById('menu-line-2');
      const menuLine3 = document.getElementById('menu-line-3');
      const desktopDropdownBtns = document.querySelectorAll('.desktop-dropdown-btn');
      const dropdownMenus = document.querySelectorAll('.dropdown-menu');
      const mobileDropdownBtns = document.querySelectorAll('.mobile-dropdown-btn');
      const mobileSearchBtn = document.getElementById('mobile-search-btn');

      // Mobile Menu Functions
      function openMobileMenu() {
        // Prevent body scroll
        document.body.style.overflow = 'hidden';
        
        // Show elements
        mobileMenu.classList.remove('hidden', 'translate-x-full');
        mobileMenuOverlay.classList.remove('hidden');
        
        // Animate in
        requestAnimationFrame(() => {
          mobileMenu.classList.add('translate-x-0');
          mobileMenuOverlay.classList.add('opacity-100');
        });
        
        // Animate hamburger to X
        menuLine1.style.transform = 'rotate(45deg) translate(6px, 6px)';
        menuLine2.style.opacity = '0';
        menuLine3.style.transform = 'rotate(-45deg) translate(6px, -6px)';
        
        // Update ARIA
        mobileMenuButton.setAttribute('aria-expanded', 'true');
        
        // Focus management
        setTimeout(() => {
          const firstFocusable = mobileMenu.querySelector('a, button');
          if (firstFocusable) firstFocusable.focus();
        }, 300);
      }

      function closeMobileMenu() {
        // Animate out
        mobileMenu.classList.remove('translate-x-0');
        mobileMenu.classList.add('translate-x-full');
        mobileMenuOverlay.classList.remove('opacity-100');
        
        // Hide elements after animation
        setTimeout(() => {
          mobileMenu.classList.add('hidden');
          mobileMenuOverlay.classList.add('hidden');
          document.body.style.overflow = '';
        }, 300);
        
        // Reset hamburger
        menuLine1.style.transform = '';
        menuLine2.style.opacity = '1';
        menuLine3.style.transform = '';
        
        // Update ARIA
        mobileMenuButton.setAttribute('aria-expanded', 'false');
        
        // Close all mobile submenus
        document.querySelectorAll('.mobile-submenu').forEach(submenu => {
          submenu.classList.add('hidden');
          submenu.classList.remove('opacity-100');
          submenu.classList.add('opacity-0');
          submenu.style.maxHeight = '0';
        });
        
        // Reset mobile dropdown buttons
        mobileDropdownBtns.forEach(btn => {
          btn.setAttribute('aria-expanded', 'false');
          const arrow = btn.querySelector('.mobile-dropdown-arrow');
          if (arrow) arrow.style.transform = '';
        });
        
        // Return focus to menu button
        mobileMenuButton.focus();
      }

      // Event Listeners
      mobileMenuButton?.addEventListener('click', openMobileMenu);
      mobileMenuCloseButton?.addEventListener('click', closeMobileMenu);
      mobileMenuOverlay?.addEventListener('click', closeMobileMenu);

      // Desktop dropdown functionality
      desktopDropdownBtns.forEach((btn, idx) => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          const menu = dropdownMenus[idx];
          const isOpen = !menu.classList.contains('hidden');
          
          // Close all dropdowns first
          dropdownMenus.forEach((m, i) => {
            m.classList.add('hidden');
            m.classList.remove('opacity-100', 'scale-100');
            m.classList.add('opacity-0', 'scale-95');
            desktopDropdownBtns[i].setAttribute('aria-expanded', 'false');
          });
          
          // Open clicked dropdown if it was closed
          if (!isOpen) {
            menu.classList.remove('hidden');
            requestAnimationFrame(() => {
              menu.classList.remove('opacity-0', 'scale-95');
              menu.classList.add('opacity-100', 'scale-100');
            });
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      // Mobile dropdown functionality
      mobileDropdownBtns.forEach((btn, idx) => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          const submenu = document.querySelector(`[data-mobile-submenu="${idx}"]`);
          const arrow = btn.querySelector('.mobile-dropdown-arrow');
          const isOpen = !submenu.classList.contains('hidden');
          
          if (isOpen) {
            // Close submenu
            submenu.classList.remove('opacity-100');
            submenu.classList.add('opacity-0');
            submenu.style.maxHeight = '0';
            
            setTimeout(() => {
              submenu.classList.add('hidden');
            }, 300);
            
            if (arrow) arrow.style.transform = '';
            btn.setAttribute('aria-expanded', 'false');
            
            // Update tabindex for submenu items
            submenu.querySelectorAll('a').forEach(link => {
              link.setAttribute('tabindex', '-1');
            });
          } else {
            // Open submenu
            submenu.classList.remove('hidden');
            submenu.style.maxHeight = submenu.scrollHeight + 'px';
            
            requestAnimationFrame(() => {
              submenu.classList.remove('opacity-0');
              submenu.classList.add('opacity-100');
            });
            
            if (arrow) arrow.style.transform = 'rotate(180deg)';
            btn.setAttribute('aria-expanded', 'true');
            
            // Update tabindex for submenu items
            submenu.querySelectorAll('a').forEach(link => {
              link.setAttribute('tabindex', '0');
            });
          }
        });
      });

      // Mobile search functionality
      mobileSearchBtn?.addEventListener('click', () => {
        // Add your search functionality here
        console.log('Mobile search clicked');
        // For example: open search modal, redirect to search page, etc.
      });

      // Close dropdowns when clicking outside
      document.addEventListener('click', e => {
        if (!e.target.closest('#main-header')) {
          dropdownMenus.forEach((m, i) => {
            m.classList.add('hidden');
            m.classList.remove('opacity-100', 'scale-100');
            m.classList.add('opacity-0', 'scale-95');
            desktopDropdownBtns[i].setAttribute('aria-expanded', 'false');
          });
        }
      });

      // Handle window resize
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024) {
          closeMobileMenu();
        }
      });

      // Keyboard navigation
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
          // Close desktop dropdowns
          dropdownMenus.forEach((m, i) => {
            m.classList.add('hidden');
            m.classList.remove('opacity-100', 'scale-100');
            m.classList.add('opacity-0', 'scale-95');
            desktopDropdownBtns[i].setAttribute('aria-expanded', 'false');
          });
          
          // Close mobile menu
          if (!mobileMenu.classList.contains('hidden')) {
            closeMobileMenu();
          }
        }
      });

      // Trap focus in mobile menu
      mobileMenu?.addEventListener('keydown', e => {
        if (e.key === 'Tab') {
          const focusableElements = mobileMenu.querySelectorAll(
            'a[href], button:not([disabled]), [tabindex="0"]'
          );
          const firstElement = focusableElements[0];
          const lastElement = focusableElements[focusableElements.length - 1];

          if (e.shiftKey) {
            if (document.activeElement === firstElement) {
              e.preventDefault();
              lastElement.focus();
            }
          } else {
            if (document.activeElement === lastElement) {
              e.preventDefault();
              firstElement.focus();
            }
          }
        }
      });

      // Header scroll effect
      let lastScrollY = window.scrollY;
      let ticking = false;

      function updateHeader() {
        const header = document.getElementById('main-header');
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > 100) {
          header.classList.add('shadow-xl');
          header.classList.remove('shadow-lg');
        } else {
          header.classList.remove('shadow-xl');
          header.classList.add('shadow-lg');
        }
        
        lastScrollY = currentScrollY;
        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateHeader);
          ticking = true;
        }
      });

      // Initialize mobile menu items tabindex
      document.querySelectorAll('.mobile-submenu a').forEach(link => {
        link.setAttribute('tabindex', '-1');
      });
    });
  </script>

  <style>
    .dropdown-menu {
      transform-origin: top center;
    }
    
    .mobile-dropdown-arrow {
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    #menu-line-1,
    #menu-line-2,
    #menu-line-3 {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .mobile-submenu {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .mobile-nav-item:hover {
      transform: translateX(2px);
    }
    
    /* Smooth scrolling for mobile menu */
    #mobile-menu {
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
    }
    
    /* Focus styles */
    .focus\:ring-2:focus {
      outline: none;
      box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.3);
    }
    
    /* Active states */
    .active\:bg-silver-light:active {
      background-color: rgba(156, 163, 175, 0.1);
    }
    
    .active\:scale-\[0\.98\]:active {
      transform: scale(0.98);
    }
    
    /* Hover animations */
    .hover\:scale-\[1\.02\]:hover {
      transform: scale(1.02);
    }
  </style>
</header>