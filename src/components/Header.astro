---
import { NAVIGATION, SITE_CONFIG } from '../utils/constants.js';

interface NavigationItem {
  name: string;
  href: string;
  submenu?: Array<{ name: string; href: string }>;
  active?: boolean;
}

function createUrl(path: string | null | undefined): string {
  if (!path) return SITE_CONFIG.url || '/';
  const clean = path.startsWith('/') ? path.slice(1) : path;
  if (clean === '' || clean === '/') return SITE_CONFIG.url || '/';
  return clean.startsWith('#')
    ? `${SITE_CONFIG.url}${clean}`
    : `${SITE_CONFIG.url}${clean}`;
}

const processedNavigation: NavigationItem[] = (NAVIGATION ?? [])
  .filter(item => item.name !== 'Kontak')
  .map(item => ({
    ...item,
    href: createUrl(item.href),
    submenu: item.submenu?.map(s => ({
      ...s,
      href: createUrl(s.href)
    })),
    active: false // Tambahkan biar TS nggak error
  }));
---

<header id="main-header" class="fixed top-0 inset-x-0 z-40 bg-silver-light border-b border-silver-mid">
  <div class="container-custom">
    <div class="flex items-center justify-between h-16">
      <a href={SITE_CONFIG.url} class="flex items-center space-x-3">
        <h1 class="text-xl font-bold text-charcoal">Tepat Laser</h1>
        <p class="hidden lg:block text-xs text-graphite">Laser Cutting Terpercaya</p>
      </a>
      <nav aria-label="Main navigation" class="hidden lg:flex items-center space-x-8">
        {processedNavigation.map((item, i) => (
          <div class="relative">
            {item.submenu ? (
              <>
                <button
                  class="desktop-dropdown-btn flex items-center space-x-1 text-charcoal hover:text-laser-green font-medium py-2"
                  data-dropdown-index={i}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  <span>{item.name}</span>
                  <svg class="w-4 h-4 dropdown-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                  </svg>
                </button>
                <div
                  data-dropdown-menu={i}
                  class="dropdown-menu hidden absolute top-full left-0 mt-2 w-56 bg-silver-light rounded-lg shadow-lg border border-silver-mid py-2 z-50"
                >
                  {item.submenu.map(s => (
                    <a
                      href={s.href}
                      class="block px-4 py-2 text-graphite hover:text-laser-green hover:bg-silver-mid text-sm font-medium"
                    >
                      {s.name}
                    </a>
                  ))}
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class="relative text-charcoal hover:text-laser-green font-medium py-2 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-laser-green after:transition-all after:duration-300 hover:after:w-full"
                class:list={{ 'text-laser-green after:w-full': item.active }}
              >
                {item.name}
              </a>
            )}
          </div>
        ))}
      </nav>
      <div class="hidden lg:flex items-center space-x-4">
        <a href={createUrl('contact')} class="btn-primary text-sm">Kontak Kita</a>
      </div>
      <button
        id="mobile-menu-button"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-silver-mid"
      >
        <svg id="menu-icon" class="w-6 h-6 text-charcoal" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
        <svg id="close-icon" class="w-6 h-6 text-charcoal hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 top-0 bg-silver-light z-50 hidden overflow-y-auto lg:hidden">
    <div class="flex items-center justify-between h-16 px-4 border-b border-silver-mid">
      <a href={SITE_CONFIG.url} class="text-xl font-bold text-charcoal">Tepat Laser</a>
      <button id="mobile-menu-close-button" aria-label="Close mobile menu" class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-silver-mid">
        <svg class="w-6 h-6 text-charcoal" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col p-4 space-y-2">
      {processedNavigation.map((item, i) => (
        <div>
          {item.submenu ? (
            <>
              <button
                data-mobile-submenu-index={i}
                aria-expanded="false"
                class="mobile-dropdown-btn flex justify-between w-full text-left text-charcoal font-medium py-3 px-4 rounded-lg hover:bg-silver-mid"
              >
                <span>{item.name}</span>
                <svg class="w-4 h-4 text-charcoal mobile-dropdown-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                </svg>
              </button>
              <div data-mobile-submenu={i} class="mobile-submenu hidden pl-4 space-y-2">
                {item.submenu.map(s => (
                  <a href={s.href} class="block text-charcoal py-2 px-4 rounded-lg hover:bg-silver-mid text-sm">{s.name}</a>
                ))}
              </div>
            </>
          ) : (
            <a href={item.href} class="block text-charcoal font-medium py-3 px-4 rounded-lg hover:bg-silver-mid">{item.name}</a>
          )}
        </div>
      ))}
      <div class="border-t border-silver-mid mt-4 pt-4">
        <a href={createUrl('contact')} class="btn-primary w-full text-center py-3">Kontak Kita</a>
      </div>
    </nav>
  </div>
  <div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

  <script type="module">
    document.addEventListener('DOMContentLoaded', () => {
      const mobileMenuButton = document.getElementById('mobile-menu-button');
      const mobileMenuCloseButton = document.getElementById('mobile-menu-close-button');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');
      const desktopDropdownBtns = document.querySelectorAll('.desktop-dropdown-btn');
      const dropdownMenus = document.querySelectorAll('.dropdown-menu');
      const mobileDropdownBtns = document.querySelectorAll('.mobile-dropdown-btn');

      function openMobileMenu() {
        mobileMenu.classList.remove('hidden');
        mobileMenuOverlay.classList.remove('hidden');
        menuIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      function closeMobileMenu() {
        mobileMenu.classList.add('hidden');
        mobileMenuOverlay.classList.add('hidden');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        document.querySelectorAll('.mobile-submenu').forEach(el => el.classList.add('hidden'));
        mobileDropdownBtns.forEach(btn => btn.setAttribute('aria-expanded', 'false'));
      }

      mobileMenuButton.addEventListener('click', openMobileMenu);
      mobileMenuCloseButton.addEventListener('click', closeMobileMenu);
      mobileMenuOverlay.addEventListener('click', closeMobileMenu);

      desktopDropdownBtns.forEach((btn, idx) => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          dropdownMenus.forEach((m, i) => {
            if (i === idx) m.classList.toggle('hidden');
            else m.classList.add('hidden');
          });
          desktopDropdownBtns.forEach((b, i) => {
            b.setAttribute('aria-expanded', i === idx && !dropdownMenus[idx].classList.contains('hidden'));
          });
        });
      });

      mobileDropdownBtns.forEach((btn, idx) => {
        btn.addEventListener('click', e => {
          e.preventDefault();
          const submenu = document.querySelector(`[data-mobile-submenu="${idx}"]`);
          const expanded = submenu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', String(!expanded));
        });
      });

      document.addEventListener('click', e => {
        if (!e.target.closest('#main-header')) {
          dropdownMenus.forEach(m => m.classList.add('hidden'));
          desktopDropdownBtns.forEach(b => b.setAttribute('aria-expanded', 'false'));
        }
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024) closeMobileMenu();
      });

      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
          dropdownMenus.forEach(m => m.classList.add('hidden'));
          desktopDropdownBtns.forEach(b => b.setAttribute('aria-expanded', 'false'));
          if (!mobileMenu.classList.contains('hidden')) closeMobileMenu();
        }
      });
    });
  </script>

  <style>
    button:focus-visible,
    a:focus-visible {
      outline: 2px solid var(--tw-color-laser-green);
      outline-offset: 2px;
    }
    .dropdown-arrow,
    .mobile-dropdown-arrow {
      transition: transform 0.2s ease-in-out;
    }
  </style>
</header>
