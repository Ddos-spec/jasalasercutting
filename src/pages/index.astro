---
// src/components/Hero.astro
// Versi Redesign: Tampilan lebih modern, dinamis, dan fokus konversi.
import { SITE_CONFIG, WHATSAPP_MESSAGES } from '../utils/constants.js';

// Props tetap fleksibel, tapi default-nya udah gue bikin lebih mantap.
export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  primaryCTA?: string;
  primaryCTALink?: string; // Link ini bisa di-override
  secondaryCTA?: string;
  secondaryCTALink?: string;
  backgroundImage?: string;
  showTrustSignals?: boolean;
}

const {
  title = "Jasa Laser Cutting #1 di Banten",
  subtitle = "Presisi Tinggi, Pengerjaan Cepat, Kualitas Terjamin",
  description = "Solusi terdepan untuk semua kebutuhan cutting Anda, mulai dari akrilik, kayu, hingga metal. Dipercaya oleh ratusan klien di Serang, Tangerang, dan Cilegon.",
  primaryCTA = "Konsultasi via WhatsApp",
  secondaryCTA = "Lihat Portfolio Kami",
  secondaryCTALink = "/portfolio/",
  // Ganti background default biar lebih relevan dengan kerjaan lo
  backgroundImage = "/jasalasercutting/images/laserfiber.webp",
  showTrustSignals = true,
} = Astro.props;

// Link WhatsApp sekarang jadi default utama, diambil dari constants.js
const whatsappLink = `https://api.whatsapp.com/send?phone=${SITE_CONFIG.whatsapp}&text=${encodeURIComponent(WHATSAPP_MESSAGES.default)}`;
---

<section class="relative h-screen min-h-[700px] flex items-center justify-center text-white overflow-hidden">
  <!-- Background Image & Overlay -->
  <div class="absolute inset-0 z-[-1]">
    <img
      src={backgroundImage}
      alt="Mesin laser cutting sedang beraksi"
      class="w-full h-full object-cover"
      loading="eager"
      width="1920"
      height="1080"
    />
    <!-- Overlay gradien yang lebih subtle dan modern -->
    <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/50 to-transparent"></div>
  </div>

  <div class="relative z-10 container-custom text-center px-4">
    <div class="max-w-3xl mx-auto">
      <!-- Subtitle/Tagline -->
      <p class="text-lg md:text-xl font-semibold text-blue-300 mb-4 animate-fade-in-up" style="animation-delay: 0.2s;">
        {subtitle}
      </p>
      
      <!-- Main Title -->
      <h1 class="text-4xl md:text-6xl font-bold mb-6 text-shadow-lg animate-fade-in-up">
        {title}
      </h1>
      
      <!-- Description -->
      <p class="text-md md:text-lg text-gray-200 mb-10 max-w-2xl mx-auto leading-relaxed animate-fade-in-up" style="animation-delay: 0.4s;">
        {description}
      </p>

      <!-- Tombol CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.6s;">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-success text-lg px-8 py-4 w-full sm:w-auto transform hover:scale-105 shadow-xl inline-flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.488"/></svg>
          {primaryCTA}
        </a>
        <a
          href={secondaryCTALink}
          class="btn-secondary border-white text-white hover:bg-white hover:text-gray-900 text-lg px-8 py-4 w-full sm:w-auto shadow-xl"
        >
          {secondaryCTA}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .text-shadow-lg {
    text-shadow: 0 2px 15px rgba(0, 0, 0, 0.5);
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }
</style>
